function main() -> void
  ALLOCI i
  MOVI 1, R1
  STOREI R1, i
  ALLOCI s
  MOVI 0, R2
  STOREI R2, s
  LABEL 'Lwhile_test1'
  LOADI i, R3
  MOVI 100, R4
  CMPI <=, R3, R4, R5
  CBRANCH R5, 'Lwhile_body2', 'Lwhile_end3'
  LABEL 'Lwhile_body2'
  LOADI s, R6
  LOADI i, R7
  ADDI R6, R7, R8
  STOREI R8, s
  LOADI i, R9
  MOVI 1, R10
  ADDI R9, R10, R11
  STOREI R11, i
  BRANCH 'Lwhile_test1'
  LABEL 'Lwhile_end3'
  LOADI s, R12
  PRINTI R12
  RET
